# Auth0 (production) — insert real values when wiring Universal Login + Token Vault
# AUTH0_DOMAIN=vaultpilot.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=   # never commit; rotate if exposed
# AUTH0_SECRET=          # random 32+ byte secret for session cookie encryption (Next.js SDK)
# APP_BASE_URL=http://localhost:3000
# AUTH0_AUDIENCE=

# GitHub as a social connection + Token Vault (AI agents / GitHub API tools)
# In Auth0 Dashboard: Authentication > Social > GitHub — enable "Connected Accounts for Token Vault".
# GitHub App (Developer Settings): Homepage URL and Callback URL point at YOUR AUTH0 DOMAIN, not this Next app:
#   Homepage URL:    https://AUTH0_DOMAIN
#   Callback URL:    https://AUTH0_DOMAIN/login/callback
# Fine-grained permissions are set on the GitHub App; Token Vault / SDK passes connection name + refresh context.
# AUTH0_CONNECTION_GITHUB=github
# AUTH0_GITHUB_SCOPES=        # often empty at vault config when using GitHub App permissions

# Token Vault / Connections — map to your Auth0 Resource Server & connection IDs
# TOKEN_VAULT_API_BASE=https://vaultpilot.us.auth0.com/api/v2
# AUTH0_CONNECTION_MOCK_BANK=con_mock_bank
# AUTH0_CONNECTION_MOCK_BILLING=con_mock_billing
# AUTH0_CONNECTION_MOCK_SAVINGS=con_mock_savings

# This MVP runs without env vars — mocks only.
